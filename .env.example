OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
# Path to OpenSCAD on the host — used by `make openscad-host` and local `dotnet run`, not Docker.
OPENSCAD_EXECUTABLE=openscad
# When set, the Docker API calls this URL instead of running OpenSCAD inside the container.
# Example: http://host.docker.internal:9333
OPENSCAD_REMOTE_URL=
MAX_CORRECTION_RETRIES=3
APP_PORT=8080
